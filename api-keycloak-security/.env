# PostgreSQL
POSTGRES_DB=bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=bankpassword

# Keycloak admin console
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# RSA private key for JWE token decryption (base64-encoded PEM).
# Keycloak encrypts access tokens with the matching public key fetched from
# GET http://api:8080/.well-known/jwks.json at login time.
# DEMO KEY — regenerate with: make generate-keys
API_PRIVATE_KEY_
